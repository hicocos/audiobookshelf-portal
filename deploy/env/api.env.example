PORTAL_PASSWORD_MIN_LENGTH=12
NEXT_PUBLIC_SITE_NAME=MoYin.CC
TELEGRAM_BOT_USERNAME=__TELEGRAM_BOT_USERNAME__
TELEGRAM_BOT_INTERNAL_TOKEN=__INTERNAL_TOKEN__
