# Docker Compose interpolation only; no service secrets belong here.
TZ=Asia/Shanghai
WEB_BIND=127.0.0.1
WEB_PORT=3009
API_BIND=127.0.0.1
API_PORT=8019
NEXT_PUBLIC_API_BASE_URL=__PORTAL_PUBLIC_URL__

# Portable host storage locations. Existing installations may keep their /www paths.
ABS_CONFIG_PATH=/srv/audiobookshelf/config
ABS_METADATA_PATH=/srv/audiobookshelf/metadata
ABS_AUDIOBOOKS_PATH=/srv/audiobookshelf/audiobooks
ABS_PODCASTS_PATH=/srv/audiobookshelf/podcasts
