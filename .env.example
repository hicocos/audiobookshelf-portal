# Copy to .env and fill real values. Never commit .env.
PORTAL_PUBLIC_URL=https://moyin.cc
APP_ENV=production
WEB_BIND=127.0.0.1
WEB_PORT=3009
API_BIND=127.0.0.1
API_PORT=8019

# Upstream media server. Keep token server-side only.
AUDIOBOOKSHELF_URL=https://your-media.example.com/audiobookshelf
AUDIOBOOKSHELF_ADMIN_TOKEN=replace-with-server-side-admin-token

DATABASE_URL=sqlite:////data/portal.db
JWT_SECRET=replace-with-at-least-32-random-bytes
ACCESS_TOKEN_EXPIRE_MINUTES=10080
SESSION_COOKIE_NAME=moyin_session
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax
CORS_ALLOWED_ORIGINS=https://moyin.cc,https://www.moyin.cc

REGISTRATION_ENABLED=true
DEFAULT_VALID_DAYS=30
PORTAL_PASSWORD_MIN_LENGTH=3

NEXT_PUBLIC_API_BASE_URL=https://moyin.cc
NEXT_PUBLIC_SITE_NAME=MoYin.CC
NEXT_PUBLIC_SITE_TITLE=MoYin.CC - 你的私人声音岛屿
NEXT_PUBLIC_SITE_DESCRIPTION=MoYin.CC 邀请注册、续期和用户中心

# Telegram Bot integration. Keep real values in .env only.
# Public bot supports both binding existing accounts and invite-code account creation:
#   /bind TG-XXXX-XXXX
#   /register username INVITE-CODE
# Protections: internal API bearer token, invite-code requirement, one Telegram ID per account,
# bot-side command rate limits, username validation.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_BOT_INTERNAL_TOKEN=replace-with-random-internal-token
TELEGRAM_BIND_CODE_TTL_MINUTES=10
TELEGRAM_BIND_CODE_MAX_FAILURES=5
TELEGRAM_SEARCH_SCAN_LIMIT=200
TELEGRAM_SEARCH_RESULT_LIMIT=8
TELEGRAM_WELCOME_IMAGE_URL=https://mikupan.com/f/30kbFd/IMG_20260712_090816_398.jpg
WEB_INTERNAL_API_BASE=http://moyin-api:8000
